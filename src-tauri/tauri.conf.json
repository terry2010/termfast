{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TermFast",
  "version": "0.3.7",
  "identifier": "com.termfast.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TermFast",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://termfast.xisj.com https://api.github.com https://github.com https://raw.githubusercontent.com; script-src 'self'"
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "A fast SSH terminal with proxy and automation",
    "longDescription": "TermFast is a fast SSH terminal with built-in SOCKS5/HTTP proxy and automation triggers for firewall updates and service recovery."
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://termfast.xisj.com/tools/latest.php"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGQ0UwOEU1ODg4ODE5NUYKUldSZkdZaUk1UWpPbjBCVXR5SVQ0d2EwZFJvRnMrNlArbGwyV01KelJkek1BY3o2SGxXU2ZrY0kK",
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
